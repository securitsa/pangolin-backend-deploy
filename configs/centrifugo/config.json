{
  "engine": "redis",
  "redis_address": "pangolin-redis:6379",
  "redis_password": "${REDIS_PASSWORD}",
  "token_hmac_secret_key": "${CENTRIFUGO_TOKEN_SECRET}",
  "api_key": "${CENTRIFUGO_API_KEY}",
  "allowed_origins": ["*"],
  "log_level": "info",
  "ping_interval": "24h",
  "pong_timeout": "23h",
  "namespaces": [
    { "name": "dialogue", "allow_subscribe_for_client": true },
    { "name": "user", "allow_subscribe_for_client": true }
  ]
}
