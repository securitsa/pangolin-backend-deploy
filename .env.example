# Copy to .env and fill in real values
# On the server, this file is generated by Ansible from vault-encrypted secrets

# PostgreSQL
POSTGRES_USER=pangolin
POSTGRES_PASSWORD=changeme

# Redis
REDIS_PASSWORD=changeme

# Centrifugo
CENTRIFUGO_API_KEY=changeme_hex32
CENTRIFUGO_TOKEN_SECRET=changeme_base64

# RabbitMQ
RABBITMQ_USER=pangolin
RABBITMQ_PASSWORD=changeme

# Inter-service auth
IDENTITY_API_KEY=changeme_jwt

# JWT
JWT_SECRET_KEYS={"prod_kid": {"kid": "prod_kid", "secret": "changeme", "valid": true}}

# Telegram
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_MODERATION_CHAT_ID=changeme

# SMS.BY
SMSBY_API_TOKEN=changeme
SMSBY_ALPHANAME_ID=changeme

# Firebase
FIREBASE_CREDENTIALS_JSON=changeme

# GHCR
GHCR_OWNER=your-github-org-or-user

# GCP Cloud Storage
GCS_PROJECT_ID=your-gcp-project-id

# Image tags
DIALOGUE_TAG=latest
IDENTITY_TAG=latest
PULSE_TAG=latest
SEMANTIC_HUB_TAG=latest
PREDICTION_HUB_TAG=latest
